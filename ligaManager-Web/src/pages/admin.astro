---
import Layout from '../layouts/Layout.astro';

interface Partido {
  id: number;          // Cambiado de id_partido a id
  local: string;       // Cambiado de id_equipoLocal a local (nombre)
  visitante: string;   // Cambiado de id_equipoVisitante a visitante (nombre)
  goles_local: number;
  goles_visitante: number;
  estado: string;
}

const response = await fetch('http://localhost:3000/api/partidos');
const partidos: Partido[] = await response.json();
---

<Layout title="Administración de Liga">
  <main class="max-w-5xl mx-auto p-6">
    <h1 class="text-3xl font-bold text-lime-500 mb-8 text-center"> 📝 Panel de Control: Partidos ⚽</h1>

    <div class="grid gap-6">
      {partidos.map((p) => (
        <div class="bg-slate-800 border border-slate-700 p-6 rounded-xl shadow-lg flex flex-wrap md:flex-nowrap items-center justify-between gap-4">
          
          <div class="flex-1">
            <span class="text-md font-mono text-indigo-400 uppercase tracking-widest block mb-1">ID: {p.id}</span>
            <div class="flex items-center gap-3 text-white font-bold text-lg">
              <span>{p.local}</span> 
              <span class="text-slate-500 font-normal">vs</span>
              <span>{p.visitante}</span>
            </div>
            <p class="text-slate-400 text-md mt-1">Estado actual: 
              <span class={`font-bold ${p.estado === 'jugado' ? 'text-green-400' : 'text-yellow-400'}`}>
                {p.estado}
              </span>
            </p>
          </div>

          <div class="flex items-center gap-4 bg-slate-900 p-4 rounded-lg border border-slate-700">
            <div class="flex flex-col">
              <label class="text-[10px] text-slate-500 uppercase mb-1">Local</label>
              <input 
                type="number" 
                min="0"
                value={p.goles_local} 
                id={`local-${p.id}`} 
                class="w-16 bg-slate-800 border border-slate-600 text-white text-center rounded py-1 focus:border-indigo-500 outline-none"
              />
            </div>

            <span class="text-slate-600 mt-4">-</span>

            <div class="flex flex-col">
              <label class="text-[10px] text-slate-500 uppercase mb-1">Visita</label>
              <input 
                type="number" 
                min="0"
                value={p.goles_visitante} 
                id={`visita-${p.id}`}
                class="w-16 bg-slate-800 border border-slate-600 text-white text-center rounded py-1 focus:border-indigo-500 outline-none"
              />
            </div>

            <div class="flex flex-col ml-2">
              <label class="text-[10px] text-slate-500 uppercase mb-1">Estado</label>
              <select 
                id={`estado-${p.id}`}
                class="bg-slate-800 border border-slate-600 text-white text-xs rounded py-1.5 px-2 outline-none"
              >
                <option value="pendiente" selected={p.estado === 'pendiente'}>Pendiente</option>
                <option value="en_juego" selected={p.estado === 'en_juego'}>En Juego</option>
                <option value="jugado" selected={p.estado === 'jugado'}>Jugado (Final)</option>
              </select>
            </div>
          </div>

          <button 
            class="update-btn bg-lime-500 hover:bg-indigo-500 text-white px-6 py-3 rounded-lg font-bold transition-all active:scale-95"
            data-id={p.id}
          >
            Actualizar
          </button>
        </div>
      ))}
    </div>
  </main>
</Layout>

<script>
  // El script permanece igual, solo asegúrate de que use 'data-id' correctamente
  const buttons = document.querySelectorAll('.update-btn');

  buttons.forEach(button => {
    button.addEventListener('click', async () => {
      const matchId = button.getAttribute('data-id');
      const golesLocalValue = parseInt((document.getElementById(`local-${matchId}`) as HTMLInputElement).value);
      const golesVisitaValue = parseInt((document.getElementById(`visita-${matchId}`) as HTMLInputElement).value);

  // VALIDACIÓN: Si alguno es menor a 0, detenemos el proceso
  if (golesLocalValue < 0 || golesVisitaValue < 0) {
    alert('❌ Los goles no pueden ser números negativos.');
    return;
  }

  // Si todo está bien, procedemos con el fetch...
  try {
    const response = await fetch(`http://localhost:3000/api/partidos/${matchId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        goles_local: golesLocalValue,
        goles_visitante: golesVisitaValue,
        estado: (document.getElementById(`estado-${matchId}`) as HTMLSelectElement).value
      })
    });

        if (response.ok) {
          alert('✅ Partido actualizado correctamente.');
          window.location.reload(); 
        } else {
          const data = await response.json();
          alert('❌ Error: ' + data.message);
        }
      } catch (error) {
        alert('No se pudo conectar con el servidor.');
      }
    });
  });
</script>