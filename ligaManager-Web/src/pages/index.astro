---
// index.astro
import Layout from '../layouts/Layout.astro';
import TablaEquipos from '../components/TablaEquipos.astro';
import TablaPartidos from '../components/TablaPartidos.astro';
import TablaPosiciones from '../components/TablaPosiciones.astro';

async function getData(url: string) {
  try {
    const response = await fetch(url);
    if (!response.ok) return []; 
    return await response.json();
  } catch (error) {
    console.error(`Error en fetch a ${url}:`, error);
    return []; 
  }
}

const equipos = await getData('http://localhost:3000/api/equipos');
const partidos = await getData('http://localhost:3000/api/partidos');
const tabla = await getData('http://localhost:3000/api/tabla-posiciones');
---

<Layout title="Liga Manager">
  <h1 class="text-3xl font-bold mb-8 text-center text-white">
    🏆 Liga de Campeones 🏆
  </h1>

  <div class="grid gap-8">
    <section class="bg-slate-900/40 p-6 rounded-xl shadow-lg border border-slate-800">
      <h2 class="text-xl font-bold mb-6 text-red-600 text-center uppercase tracking-widest">
        Tabla de Posiciones
      </h2>
      <TablaPosiciones tabla={tabla} />
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <section class="lg:col-span-4 bg-slate-900/40 p-6 rounded-xl shadow-lg border border-slate-800">
        <h2 class="text-xl font-bold mb-4 text-white text-center uppercase tracking-wider">
          Equipos
        </h2>
        <TablaEquipos equipos={equipos} />
      </section>

      <section class="lg:col-span-8 bg-slate-900/40 p-6 rounded-xl shadow-lg border border-slate-800">
        <h2 class="text-xl font-bold mb-4 text-white text-center uppercase tracking-wider">
          Calendario de Partidos
        </h2>
        <TablaPartidos partidos={partidos} />
      </section>
    </div>
  </div>
</Layout>