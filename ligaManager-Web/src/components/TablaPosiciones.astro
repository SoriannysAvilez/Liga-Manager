---
// 1. Definimos la estructura de una fila de la tabla
interface FilaTabla {
  nombre: string;
  PJ: number;
  PG: number;
  PE: number;
  PP: number;
  puntos: number;
}

interface Props {
  tabla: FilaTabla[];
}

const { tabla } = Astro.props;
---

<div class="overflow-hidden rounded-xl border border-slate-700 shadow-xl mb-8">
  <table class="w-full text-sm md:text-base border-collapse bg-slate-800">
    <thead>
      <tr class="bg-slate-900 border-b border-slate-700 text-indigo-400 uppercase tracking-wider">
        <th class="py-4 px-3 text-center w-12">#</th>
        <th class="py-4 px-6 text-left">Equipo</th>
        <th class="py-4 px-3 text-center font-medium">PJ</th>
        <th class="py-4 px-3 text-center font-medium text-green-400/80">PG</th>
        <th class="py-4 px-3 text-center font-medium text-yellow-400/80">PE</th>
        <th class="py-4 px-3 text-center font-medium text-red-400/80">PP</th>
        <th class="py-4 px-6 text-center font-bold bg-slate-900/50 text-indigo-300">PTS</th>
      </tr>
    </thead>
    
    <tbody class="divide-y divide-slate-700">
      {tabla.map((t, i) => (
        <tr class="hover:bg-indigo-600/10 transition-colors duration-200 group">
          <td class={`py-4 px-3 text-center font-mono ${i < 3 ? 'text-indigo-400 font-bold' : 'text-slate-500'}`}>
            {i + 1}
          </td>
          
          <td class="py-4 px-6 text-white font-semibold group-hover:text-indigo-300">
            {t.nombre}
          </td>
          
          <td class="py-4 px-3 text-center text-slate-300">{t.PJ}</td>
          <td class="py-4 px-3 text-center text-slate-300">{t.PG}</td>
          <td class="py-4 px-3 text-center text-slate-300">{t.PE}</td>
          <td class="py-4 px-3 text-center text-slate-300">{t.PP}</td>
          
          <td class="py-4 px-6 text-center">
            <span class="inline-block w-8 py-1 rounded-md bg-indigo-500/10 text-indigo-300 font-bold border border-indigo-500/20">
              {t.puntos}
            </span>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>